# ─── Required ────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Admin bearer token for /admin/* endpoints — keep secret, rotate regularly
ADMIN_API_TOKEN=your-strong-random-token-here

# ─── Optional collection names (defaults shown) ──────────────
# DB_NAME=gharsip_store
# ORDERS_COLLECTION=gharsip_orders
# BOOKINGS_COLLECTION=gharsip_bookings
# META_COLLECTION=gharsip_meta
# OTP_COLLECTION=gharsip_email_otps
# USERS_COLLECTION=gharsip_users
# PRODUCTS_COLLECTION=gharsip_products

# ─── Email OTP — Brevo ───────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@gharsip.in
BREVO_SENDER_NAME=Gharsip

# ─── Image uploads — ImgBB ───────────────────────────────────
IMGBB_API_KEY=your-imgbb-api-key

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://gharsip.in,https://www.gharsip.in
