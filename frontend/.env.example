# ─── Required ────────────────────────────────────────────────
# Backend API base URL (FastAPI on Render)
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# Admin dashboard PIN — CHANGE THIS before going live
NEXT_PUBLIC_ADMIN_PIN=your-secure-pin-here

# WhatsApp ordering number (with country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=916305468471

# UPI ID for direct customer payments (shown as QR code + pay link at checkout)
NEXT_PUBLIC_UPI_ID=6305468471@upi

# ─── Admin (server-side) ──────────────────────────────────────
# Bearer token for backend /api/admin/* — must match backend's ADMIN_API_TOKEN
ADMIN_API_TOKEN=your-strong-random-token-here
# Optional: overrides which PIN the Next.js admin proxy accepts
# PRINTS_OPS_PIN=your-secure-pin-here
